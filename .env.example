# DeepResearch Environment Configuration (Nvidia Brev Backend)
# Copy this file to .env and fill in your actual values
# Run: cp .env.example .env

# =============================================================================
# Nvidia Brev API Configuration
# Generate your API key at: https://console.brev.dev (Account Settings > API Keys)
# =============================================================================

# Brev API key (shared across all deployments)
BREV_API_KEY=your_brev_api_key

# Main agent model deployment (Nemotron-3-Super-120B-A12B)
# Create a deployment at: https://console.brev.dev/deployments
BREV_MAIN_DEPLOYMENT_ID=your_main_deployment_id
BREV_MAIN_BASE_URL=https://api.brev.dev/v1/deployments/${BREV_MAIN_DEPLOYMENT_ID}
BREV_MAIN_MODEL_NAME=nvidia/nemotron-3-super-120b-a12b

# Summarization model deployment (used by tool_visit for page summarization)
# Can share the same deployment ID as the main model
BREV_SUMMARY_DEPLOYMENT_ID=your_summary_deployment_id
BREV_SUMMARY_BASE_URL=https://api.brev.dev/v1/deployments/${BREV_SUMMARY_DEPLOYMENT_ID}
BREV_SUMMARY_MODEL_NAME=nvidia/nemotron-3-super-120b-a12b

# Evaluation judge model deployment
BREV_EVAL_DEPLOYMENT_ID=your_eval_deployment_id
BREV_EVAL_BASE_URL=https://api.brev.dev/v1/deployments/${BREV_EVAL_DEPLOYMENT_ID}
BREV_EVAL_MODEL_NAME=nvidia/nemotron-3-super-120b-a12b

# HuggingFace tokenizer ID matching the main deployed model (for token counting)
TOKENIZER_ID=nvidia/NVIDIA-Nemotron-3-Super-120B-A12B-BF16

# =============================================================================
# DeepResearch Configuration
# =============================================================================
QWEN_DOC_PARSER_USE_IDP=false
QWEN_IDP_ENABLE_CSI=false
NLP_WEB_SEARCH_ONLY_CACHE=false
NLP_WEB_SEARCH_ENABLE_READPAGE=false
NLP_WEB_SEARCH_ENABLE_SFILTER=false
QWEN_SEARCH_ENABLE_CSI=false
SPECIAL_CODE_MODE=false
PYTHONDONTWRITEBYTECODE=1

# =============================================================================
# Inference Hyperparameters
# =============================================================================
DATASET=your_dataset_name
OUTPUT_PATH=/your/output/path
ROLLOUT_COUNT=3
TEMPERATURE=1.0
PRESENCE_PENALTY=1.1
MAX_WORKERS=30

# =============================================================================
# API Keys and External Services
# =============================================================================

# Serper API for web search and Google Scholar
# Get your key from: https://serper.dev/
SERPER_KEY_ID=your_key

# Jina API for web page reading
# Get your key from: https://jina.ai/
JINA_API_KEYS=your_key

# X/Twitter API Bearer Token for trending topics and post search
# Get your key from: https://developer.x.com/
X_BEARER_TOKEN=your_x_bearer_token

# =============================================================================
# Python Code Execution Sandbox
# =============================================================================

# SandboxFusion endpoints for Python interpreter
# Example: "http://22.16.67.220:8080,http://22.16.78.153:8080,http://22.17.10.216:8080"
# See: https://github.com/bytedance/SandboxFusion
SANDBOX_FUSION_ENDPOINT=your_sandbox_endpoint

# =============================================================================
# Multi-Worker Configuration (Optional)
# =============================================================================

# These are typically set by distributed training frameworks
# WORLD_SIZE=1
# RANK=0
